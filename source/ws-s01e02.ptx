<exercise>
    <introduction>
        <p>
            Answer the following word problems:
        </p>
    </introduction>
    <task workspace="1.25in">
        <statement>
            <p>
                A bookstore packs 24 boxes, and each box holds 18 books. How many books are packed in total?
            </p>
        </statement>
    </task>
    <task workspace="1.25in">
        <statement>
            <p>
                A teacher has 144 pencils and wants to give them equally to 12 students. How many pencils does each student get?
            </p>
        </statement>
    </task>
    <task workspace="1.25in">
        <statement>
            <p>
            A delivery truck carries 960 bottles of water. The bottles are packed equally into crates, each crate containing 24 bottles. How many crates can be filled?
            </p>
        </statement>
    </task>
    <task workspace="1.25in">
        <statement>
            <p>
                A bookstore packs 24 boxes, and each box holds 18 books. How many books are packed in total?
            </p>
        </statement>
    </task>
</exercise>
</worksheet>