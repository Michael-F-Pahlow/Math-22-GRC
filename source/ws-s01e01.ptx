  <exercise>
  <introduction>
    <p>
      Answer these word problems
    </p>
  </introduction>
    <task workspace="1.0in">
      <statement>
        <p>
          Mia has 3 apples. Her friend gives her 4 more apples. How many apples does Mia have now?
        </p>
      </statement>
    </task>
    <task workspace="1.0in">
      <statement>
        <p>
          There are 8 pencils on a desk. 5 pencils are taken away. How many pencils are left on the desk?
        </p>
      </statement>
    </task>
    <task workspace="1.0in">
      <statement>
        <p>
          2 birds are sitting on a fence. 5 more birds fly over and land on the fence. How many birds are on the fence in total?
        </p>
      </statement>
    </task>
    <task workspace="1.0in">
      <statement>
        <p>
          Leo has 9 cookies. He eats 3 of them. How many cookies does Leo have left?
        </p>
      </statement>
    </task>
  </exercise>

  <exercise>
  <introduction>
    <p>
      Interpret the key words to answer the following questions. 
    </p>
  </introduction>
    
  <task workspace="1.0in">
    <statement>
      <p>
        What is the <alert>sum</alert> of 3 and 5?
      </p>
    </statement>
  </task>
  <task workspace="1.0in">
    <statement>
      <p>
        What is the <alert>difference</alert> between 9 and 4?
      </p>
    </statement>
  </task>
  <task workspace="1.0in">
    <statement>
      <p>
        Find the <alert>sum</alert> of 6 and 2?
      </p>
    </statement>
  </task>
  <task workspace="1.0in">
    <statement>
      <p>
        Find the <alert>difference</alert> between 8 and 3?
      </p>
    </statement>
  </task>
  </exercise>
</worksheet>