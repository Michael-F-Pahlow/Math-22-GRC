<worksheet xml:id="ws-s01e01">
  <title>Episode 1 Practice Problems</title>
  <exercise>
  <introduction>
    <p>
       Calculate the following values by hand.
    </p>
  </introduction>
       
      <task workspace="0.5in">
      <statement>
        <p>
          <md> 9-5 = \hspace{1.5in} 1+7= \hspace{1.5in} 2+5=\hspace{1.5in}</md>
        </p>
      </statement>
    </task>
    <task workspace="0.5in">
      <statement>
        <p>
          <md> 6+2 = \hspace{1.5in} 5+4= \hspace{1.5in} 9-1=\hspace{1.5in}</md>
        </p>
      </statement>
    </task>
    <task workspace="0.5in">
      <statement>
        <p>
          <md> 8-3 = \hspace{1.5in} 7-6= \hspace{1.5in} 4+3=\hspace{1.5in}</md>
        </p>
      </statement>
    </task>
  </exercise>
  
