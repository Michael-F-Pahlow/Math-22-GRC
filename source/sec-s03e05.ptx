            </p>
        </exercise>
        <exercise workspace="1.0in">
            <p>
                Convert 12 feet to inches.
            </p>
        </exercise>
        <exercise workspace="1.0in">
            <p>
               Convert 540 seconds to minutes. 
            </p>
        </exercise>
        <exercise workspace="1.0in">
            <p>
                Convert 36 inches to feet.
            </p>
        </exercise>
        <exercise workspace="1.0in">
            <p>
               Convert 62 kilograms to grams. 
            </p>
        </exercise>
        <exercise workspace="1.0in">
            <p>
                Convert 5 miles to feet.
            </p>
        </exercise>
        <exercise workspace="1.0in">
            <p>
                Convert 9000 milligrams to grams.
            </p>
        </exercise>
        <exercise workspace="1.0in">
            <p>
                Convert 2,640 feet to miles.
            </p>
        </exercise>
     </worksheet>
</section>